{
  "name": "accounting-api",
  "version": "1.1.0",
  "description": "Indonesian accounting API",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "cross-env NODE_ENV=development nest start",
    "start:dev": "cross-env NODE_ENV=development nest start --watch",
    "start:debug": "cross-env NODE_ENV=development nest start --debug --watch",
    "start:prod": "cross-env NODE_ENV=production node dist/src/main",
    "openapi:export": "nest build && node dist/src/scripts/export-openapi.js",
    "db:migrate": "dotenv -e .env.development -- prisma migrate dev",
    "db:reset": "dotenv -e .env.development -- prisma migrate reset",
    "db:studio": "dotenv -e .env.development -- prisma studio",
    "db:generate": "prisma generate",
    "create-admin": "dotenv -e .env.development -- ts-node scripts/create-admin.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "lint:ci": "eslint \"{src,apps,libs,test}/**/*.ts\" --max-warnings 0",
    "coverage:merge": "rm -rf .nyc_output coverage-merged && mkdir -p .nyc_output && cp coverage/coverage-final.json .nyc_output/unit.json && cp coverage-e2e/coverage-final.json .nyc_output/e2e.json && nyc report && nyc check-coverage",
    "test:cov:all": "npm run test:cov && npm run test:e2e:cov && npm run coverage:merge",
    "verify": "npm run typecheck && npm run lint:ci && npm run test:cov:all",
    "audit:ci": "npm audit --omit=dev --audit-level=moderate",
    "audit:dev": "npm audit --audit-level=moderate || true",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:e2e:cov": "jest --config ./test/jest-e2e.json --coverage"
  },
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10"
  },
  "dependencies": {
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.6",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "@sentry/node": "^10.67.0",
    "argon2": "^0.45.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "decimal.js": "^10.6.0",
    "helmet": "^8.3.0",
    "ioredis": "^5.11.1",
    "ms": "^2.1.3",
    "nestjs-pino": "^4.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.22.0",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.28",
    "@testcontainers/postgresql": "^12.0.4",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.1",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.7.0",
    "jest": "^30.0.0",
    "nyc": "^18.0.0",
    "prettier": "^3.9.6",
    "prisma": "^7.9.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "testcontainers": "^12.0.1",
    "ts-jest": "^29.4.12",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.65.0"
  },
  "overrides": {
    "multer": "^2.2.0",
    "form-data": "^4.0.6",
    "@hono/node-server": "^1.19.14",
    "js-yaml": "^4.2.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.ts",
      "!**/*.spec.ts",
      "!**/*.dto.ts",
      "!**/main.ts",
      "!**/*.module.ts",
      "!**/scripts/**"
    ],
    "coverageDirectory": "../coverage",
    "coverageThreshold": {
      "global": {
        "statements": 30,
        "branches": 29,
        "functions": 26,
        "lines": 29
      },
      "**/reporting/cash-flow.service.ts": {
        "statements": 90,
        "branches": 90,
        "functions": 90,
        "lines": 90
      },
      "**/reporting/balance-sheet.service.ts": {
        "statements": 90,
        "branches": 90,
        "functions": 90,
        "lines": 90
      },
      "**/reporting/income-statement.service.ts": {
        "statements": 90,
        "branches": 90,
        "functions": 90,
        "lines": 90
      }
    },
    "testEnvironment": "node"
  }
}
